{
  "name": "plattsburgh-rideshare",
  "version": "1.0.0",
  "description": "Uber-like ride-sharing platform for Plattsburgh, NY",
  "main": "server/index.ts",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:rider\" \"npm run dev:driver\" \"npm run dev:admin\"",
    "dev:server": "tsx watch server/index.ts",
    "dev:rider": "cd apps/rider && npm run dev",
    "dev:driver": "cd apps/driver && npm run dev",
    "dev:admin": "cd apps/admin && npm run dev",
    "build": "npm run build:server && npm run build:rider && npm run build:driver && npm run build:admin",
    "build:server": "tsc",
    "build:rider": "cd apps/rider && npm run build",
    "build:driver": "cd apps/driver && npm run build",
    "build:admin": "cd apps/admin && npm run build",
    "start": "node dist/index.js",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "keywords": [
    "rideshare",
    "uber",
    "plattsburgh",
    "transportation"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.44.7",
    "express": "^4.22.1",
    "jsonwebtoken": "^9.1.2",
    "pg": "^8.11.3",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.19.3",
    "@types/uuid": "^9.0.7",
    "concurrently": "^9.2.1",
    "drizzle-kit": "^0.31.8",
    "eslint": "^9.39.2",
    "prettier": "^3.7.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
